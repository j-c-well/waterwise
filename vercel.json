{
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" }
      ]
    }
  ],
  "functions": {
    "api/scrape.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/scrape", "destination": "/api/scrape.js" },
    { "source": "/api/data", "destination": "/api/data.js" },
    { "source": "/api/history", "destination": "/api/history.js" }
  ]
}
