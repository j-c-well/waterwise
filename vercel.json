{
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" }
      ]
    }
  ],
  "functions": {
    "api/scrape.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/scrape", "destination": "/api/scrape.js" },
    { "source": "/api/data", "destination": "/api/data.js" },
    { "source": "/api/history", "destination": "/api/history.js" },
    { "source": "/api/household/profile", "destination": "/api/household/profile.js" },
    { "source": "/api/household/event-log", "destination": "/api/household/event-log.js" },
    { "source": "/api/household/event-correction", "destination": "/api/household/event-correction.js" },
    { "source": "/api/household/scan-label", "destination": "/api/household/scan-label.js" },
    { "source": "/api/corrected", "destination": "/api/corrected.js" },
    { "source": "/api/household/daily-timeline",    "destination": "/api/household/daily-timeline.js" },
    { "source": "/api/household/shower-log",         "destination": "/api/household/shower-log.js" },
    { "source": "/api/household/shower-autoassign",  "destination": "/api/household/shower-autoassign.js" },
    { "source": "/api/user/register",                "destination": "/api/user/register.js" },
    { "source": "/api/user/data",                    "destination": "/api/user/data.js" },
    { "source": "/api/user/status",                  "destination": "/api/user/status.js" }
  ]
}
